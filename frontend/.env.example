# Base URL of the FastAPI backend (baked into the bundle at build time).
#
# Dev (npm run dev): falls back to http://localhost:8000 if unset — copy this
# file to .env to override.
VITE_API_BASE_URL=http://localhost:8000
#
# Production builds (npm run build / npm run preview) read .env.production:
#   VITE_API_BASE_URL=https://api.workspaceai.thefirstimpression.ai
