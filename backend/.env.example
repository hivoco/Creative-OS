# Copy to .env and fill in.

# MySQL connection (PyMySQL driver). Create the database first:
#   CREATE DATABASE creative_os CHARACTER SET utf8mb4;
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/creative_os

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Gemini (Google AI Studio key). Leave blank to fall back to a no-op translator.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Segmind — AI smart-resize (nano-banana-pro), Video AI portrait (nano-banana-2)
# + lipsync (InfiniteTalk). Leave blank to disable those features.
SEGMIND_API_KEY=

# Fish Audio — voice cloning + TTS for the Video AI tool.
FISH_API_KEY=

# AWS S3 — needed so Segmind can fetch the blank (public URL) and store the
# resized output. Leave blank to disable smart-resize.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=
S3_BASE_PREFIX=creative_os

# Local file storage for blank template images (served at /uploads).
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:8000

# CORS (comma-separated origins). Frontend dev server defaults to 6101.
CORS_ORIGINS=http://localhost:6101,http://127.0.0.1:6101
